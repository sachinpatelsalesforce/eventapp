# PostgreSQL — auto-set by Heroku Postgres add-on
DATABASE_URL=postgres://user:password@host:5432/dbname

# JWT signing secret for admin sessions — generate: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# Admin password (only used during create-admin script)
ADMIN_PASSWORD=changeme

# OpenAI API key for AI Event Concierge
OPENAI_API_KEY=sk-...

# Production URL (used by Next.js for canonical links)
NEXTAUTH_URL=https://your-app.herokuapp.com

NODE_ENV=production
